  "description": "Backend for SkillSwap Hub - Peer-to-peer barter marketplace",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "nodemon server.js",
    "test": "jest",
    "script": "node scripts/seedDatabase.js",
